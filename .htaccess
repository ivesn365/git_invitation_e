<Files .htaccess>
order allow,deny
deny from all
</Files>



# Ăviter le spam de commentaires



### FILTRE CONTRE CERTAINS ROBOTS DES PIRATES
RewriteEngine On
## EXCEPTION: TOUS LES ROBOTS MĂMES ANONYMES OU BANNIS PEUVENT ACCĂDER Ă CES FICHIERS
RewriteCond %{REQUEST_URI} !^robots.txt
RewriteCond %{REQUEST_URI} !^sitemap.xml
## ANONYMES
RewriteCond %{HTTP_USER_AGENT} ^-?$ [OR]
## BIBLIOTHĂQUES / CLASSES HTTP DONT ON NE VEUT PAS. ATTENTION, CELA PEUT BLOQUER CERTAINES FONCTIONS DE VOTRE CMS. NE PAS TOUT EFFACER, MAIS CHERCHEZ LE NOM DE LA CLASSE HTTP CONCERNĂE (DEMANDEZ AUX DĂVELOPPEURS DE VOTRE CMS). CETTE LISTE BLOQUE 80% DES ROBOTS SPAMMEURS. IL FAUT LA CONSERVER.
RewriteCond %{HTTP_USER_AGENT} ^curl|^Fetch\ API\ Request|GT::WWW|^HTTP::Lite|httplib|^Java|^LeechFTP|lwp-trivial|^LWP|libWeb|libwww|^PEAR|PECL::HTTP|PHPCrawl|PycURL|^ReGet|Rsync|Snoopy|URI::Fetch|urllib|WebDAV|^Wget|^AnyConnect|Nmap\ Scripting [NC]
## CEUX QUI INVENTENT DES NOMS AU HASARD, RETIREZ LES 2 DIĂSES EN DĂBUT DE LIGNE POUR L'ACTIVER
## RewriteCond %{HTTP_USER_AGENT} ^[bcdfghjklmnpqrstvwxz\ ]{10,}|^[0-9a-z]{15,}|^[0-9A-Za-z]{19,}|^[A-Za-z]{3,}\ [a-z]{4,}\ [a-z]{4,} [OR]
RewriteRule (.*) [F]

##Interdire l'affichage de certains formats de fichiers


Options -Indexes


## DĂŠfinissez le fichier par dĂŠfaut





# RĂŠĂŠcriture de index$ vers index.php
RewriteRule ^page-accueil$  index.php
RewriteRule ^page-connexion$  login.php
RewriteRule ^model/Connexion.php$  erreur.php [L]
RewriteRule ^sitemap.xml$  erreur.php [L]
RewriteRule ^robots.txt$  erreur.php [L]


# RĂŠĂŠcriture des URL
RewriteRule ^page-([0-9a-zA-Z\-]+)$  index.php?page=$1 [L]

RewriteRule ^pages-([0-9a-zA-Z\-]+)-([0-9a-zA-Z\-]+)$  index.php?page=$1&voirTout=$2 [L]
RewriteRule ^update-([0-9a-zA-Z\-]+)-([0-9a-zA-Z\-]+)$  index.php?page=$1&id=$2 [L]
RewriteRule ^detail-([0-9a-zA-Z\-]+)-([0-9a-zA-Z\-]+)$  index.php?page=$1&id=$2 [L]
RewriteRule ^form-([0-9a-zA-Z\-]+)-([0-9a-zA-Z\-]+)$  index.php?page=$1&log=$2 [L]
RewriteRule ^data.html$  sysControl/Controleur.php [L]
RewriteRule ^print-([0-9a-zA-Z\-]+)$  controlleur/controlleur.php?saveFile=$1 [L]
RewriteRule ^print-exercices$  controlleur/controlleur.php?printExercice=yes[L]
RewriteRule ^print-invoice.html$   facture.php [L]
RewriteRule ^index.html$   index.php [L]
RewriteRule ^connexion.html$  login.php [L]
RewriteRule ^connexion-log-no.html$  login.php?log=no [L]
RewriteRule ^modifierMotDePasse.html$  clogin.php [L]
RewriteRule ^facture-([0-9a-zA-Z\-]+)$  invoice.php?id=$1 [L]
RewriteRule ^invitation.html$  invitation_pdf.php [L]
RewriteRule ^print-livre-or.html$  livre_or_imprimer.php [L]
RewriteRule ^print-([0-9a-zA-Z\-]+)-livre-or.html$  livre_or_imprimer.php?id_event=$1 [L]

RewriteRule ^tp-log-succesfull.html$  index.php?index=accueil&log=success [L]
RewriteRule ^deconnexion.html$  controlleur/controlleur.php?quitSession=$1 [L]
RewriteRule ^printpiecejoint-([0-9])-joint.html$  controlleur/Controlleur.php?print_piece_joint=$1 [L]

RewriteRule ^resto.html$  bars/index.php [L]

RewriteRule ^ihs-event-message$  invite.php [L]
RewriteRule ^ihs-event-invitation  Mariage/index.php [L]

